<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Мои полеты</title>
    <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
    <script src="./script.js" type="module"></script>
</head>
<body class="bg-gray-100 flex items-center justify-center min-h-screen">
    <div class="bg-white p-8 rounded-lg shadow-md w-full max-w-6xl">
        <h2 class="text-2xl font-bold mb-6 text-center">Мои полеты</h2>
        <div class="overflow-x-auto">
            <table class="min-w-full bg-white border border-gray-300">
                <thead>
                    <tr class="bg-gray-200">
                        <th class="py-2 px-4 border-b text-left">Локация</th>
                        <th class="py-2 px-4 border-b text-left">БПЛА</th>
                        <th class="py-2 px-4 border-b text-left">Статус</th>
                        <th class="py-2 px-4 border-b text-left">Дата начала</th>
                        <th class="py-2 px-4 border-b text-left">Дата окончания</th>
                        <th class="py-2 px-4 border-b text-left">Дата добавления</th>
                    </tr>
                </thead>
                <tbody id="tbody"></tbody>
            </table>
        </div> <!-- Конец контейнера -->
        <div class="flex justify-left mt-6">
            <button
                id="add-uav-flight"
                class="bg-blue-500 text-white py-2 px-4 rounded-md hover:bg-blue-600 transition duration-200"
            >
                Добавить полет
            </button>
            <button
                id="back"
                class="bg-gray-500 ml-3 text-white py-2 px-4 rounded-md hover:bg-gray-600 transition duration-200"
            >
                Назад
            </button>
        </div>
    </div>
</body>
</html>
